# Скопируйте в .env или задайте переменные окружения перед запуском.
# Для отправки писем «Забыли пароль» на реальный email:

# Gmail (используйте «Пароль приложения», не обычный пароль):
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=ваш_email@gmail.com
# MAIL_PASSWORD=ваш_пароль_приложения
# MAIL_USE_TLS=1
# MAIL_FROM=ваш_email@gmail.com

# Яндекс:
# MAIL_SERVER=smtp.yandex.ru
# MAIL_PORT=587
# MAIL_USERNAME=ваш@yandex.ru
# MAIL_PASSWORD=пароль
# MAIL_USE_TLS=1
# MAIL_FROM=ваш@yandex.ru
